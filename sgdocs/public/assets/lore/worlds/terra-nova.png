<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 500">
  <defs>
    <radialGradient id="planet-grad" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#a01030"/>
      <stop offset="100%" style="stop-color:#0b0d17"/>
    </radialGradient>
  </defs>
  <rect width="800" height="500" fill="#0b0d17"/>
  <circle cx="400" cy="250" r="120" fill="url(#planet-grad)"/>
  <ellipse cx="400" cy="250" rx="180" ry="40" fill="none" stroke="#800020" stroke-width="2" transform="rotate(-30 400 250)"/>
  <text x="400" y="420" text-anchor="middle" fill="#800020" font-size="24" font-family="Arial">Терра Нова</text>
</svg>
