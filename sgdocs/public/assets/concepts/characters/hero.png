<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 500">
  <defs>
    <linearGradient id="char-bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e2138"/>
      <stop offset="100%" style="stop-color:#2a2d4a"/>
    </linearGradient>
  </defs>
  <rect width="800" height="500" fill="url(#char-bg)"/>
  <text x="400" y="240" text-anchor="middle" fill="#800020" font-size="24" font-family="Arial">Концепт-арт</text>
  <text x="400" y="280" text-anchor="middle" fill="#a01030" font-size="16" font-family="Arial">Персонаж</text>
  <circle cx="400" cy="150" r="60" fill="none" stroke="#800020" stroke-width="3"/>
  <circle cx="400" cy="150" r="40" fill="none" stroke="#a01030" stroke-width="2"/>
  <rect x="340" y="320" width="120" height="100" rx="10" fill="none" stroke="#800020" stroke-width="2"/>
</svg>
